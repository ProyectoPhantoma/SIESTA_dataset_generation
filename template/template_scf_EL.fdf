# ============================================================
# Generic SCF template for single-element density datasets
# Placeholders are replaced by the generator script
# ============================================================

SystemName      __EL___dataset
SystemLabel     __SYSTEM_LABEL__

NumberOfAtoms      __NATOMS__
NumberOfSpecies    1

%block ChemicalSpeciesLabel
  1  __Z__  __EL__
%endblock ChemicalSpeciesLabel

# ---------- LATTICE ----------
LatticeConstant  1.0 Ang

%block LatticeVectors
__LV1__
__LV2__
__LV3__
%endblock LatticeVectors

# ---------- ATOMS ----------
AtomicCoordinatesFormat  Ang

%block AtomicCoordinatesAndAtomicSpecies
__COORDS__
%endblock AtomicCoordinatesAndAtomicSpecies

# ============================================================
# ELECTRONIC STRUCTURE (SCF ONLY)
# ============================================================

# ---- Spin ----
# Uncomment the following line if you later want spin-polarized runs.
# Spin   polarized

XC.functional       GGA
XC.authors          PBE

# ---------- BASIS ----------
PAO.BasisSize       TZP
PAO.EnergyShift     0.01 eV

# ---------- REAL-SPACE GRID ----------
MeshCutoff          400 Ry

# ---------- SCF ----------
SolutionMethod      diagon
MaxSCFIterations    150

DM.Tolerance        1.d-4
DM.MixingWeight     0.10
DM.NumberPulay      8

ElectronicTemperature   300 K
OccupationFunction      FD

# ---------- K-POINTS ----------
%block kgrid_Monkhorst_Pack
  12   0   0   0.0
   0  12   0   0.0
   0   0  12   0.0
%endblock kgrid_Monkhorst_Pack

# ============================================================
# OUTPUT CONTROL
# ============================================================

WriteForces                  .false.
WriteMullikenPop             0
WriteEigenvalues             .false.
WriteBands                   .false.
WriteDOS                     .false.

SaveRho                      .true.
SaveElectrostaticPotential   .true.
DM.Save                      .true.

# ============================================================
# END
# ============================================================